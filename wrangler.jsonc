{
  "name": "monday-super-mail-backend",
  "main": "src/index.ts",
  "compatibility_date": "2024-01-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "SUPERMAIL_DB",
      "database_id": "local",
      "migrations_dir": "backend/src/db/migrations"
    }
  ],
  "vars": {
    "ENVIRONMENT": "dev"
  }
}
